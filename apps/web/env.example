# Optional: Solana devnet RPC for Cloak + wallet flows (defaults to api.devnet.solana.com).
# Cloak devnet relay is https://api.devnet.cloak.ag (preconfigured in @cloak.dev/sdk-devnet).
NEXT_PUBLIC_SOLANA_DEVNET_RPC="https://api.devnet.solana.com"

# PostgreSQL — required by Prisma CLI (prisma.config.ts) and the app (lib/prisma.ts).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
# Neon: https://neon.tech/docs/connect/connect-from-any-app
# Prisma + Postgres: https://www.prisma.io/docs/prisma-orm/add-to-existing-project/postgresql
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?schema=public&sslmode=require"

# Optional: Prisma Migrate shadow DB (or use a non-pooled direct URL here if Neon documents it).
# shadowDatabaseUrl: https://www.prisma.io/docs/orm/prisma-migrate/understanding-prisma-migrate/shadow-database
# SHADOW_DATABASE_URL="postgresql://..."

# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# Public URL of this app (checkout emails and SDK default host). Example: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: extra entropy when hashing merchant API keys (trx_live_…). Set in production.
# TREASURIX_API_KEY_PEPPER="long-random-string"

# Optional: default base URL for treasurix-checkout-sdk on your machine (SDK also accepts constructor baseUrl).
# TREASURIX_BASE_URL="http://localhost:3000"


SMTP_ENABLED="true"
SMTP_HOST="m"
SMTP_PORT="587"
SMTP_USER=""
BREVO_API_KEY=""